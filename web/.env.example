# Address of the deployed Launchpad contract (from `forge script script/Deploy.s.sol`).
# While unset/zero, the app runs on its built-in mock-data layer.
NEXT_PUBLIC_LAUNCHPAD_ADDRESS=0x0000000000000000000000000000000000000000

# --- Listing filters (optional) ---
# Hide specific tokens from the listings (home / trending / stats). Comma-separated addresses.
# The tokens still exist on-chain and their /token/<address> page still works.
NEXT_PUBLIC_HIDDEN_TOKENS=

# Hide every token launched BEFORE this instant — sweep old contracts off the site without a deploy.
# Accepts a unix timestamp (seconds) or a date string, e.g. `2026-07-15` or `2026-07-15T00:00:00Z`.
# Empty/unset = show everything. Only filters the lists; the /token/<address> page still works.
NEXT_PUBLIC_HIDE_TOKENS_BEFORE=
